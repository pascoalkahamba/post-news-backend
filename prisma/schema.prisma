// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int          @id @default(autoincrement())
  email          String       @unique
  password       String       @unique
  username       String
  cellPhone      String       @unique
  resetToken     String?      @unique
  resetExpiresAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  role           Role         @default(USER)
  posts          Post[]
  reactions      Reaction[]
  profile        Profile?
  friendships    Friendship[]
  Comments       Comment[]
  Replies        Reply[]
}

model Profile {
  id      Int      @id @default(autoincrement())
  bio     String
  picture Picture?
  user    User     @relation(fields: [userId], references: [id])
  userId  Int      @unique
}

model Category {
  id          Int    @id @default(autoincrement())
  name        String
  description String
  posts       Post[]
}

model Post {
  id         Int        @id @default(autoincrement())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  title      String     @db.VarChar(255)
  picture    Picture?
  comments   Comment[]
  reactions  Reaction[]
  content    String     @db.LongText
  published  Boolean    @default(false)
  category   Category   @relation(fields: [categoryId], references: [id])
  author     User       @relation(fields: [authorId], references: [id])
  authorId   Int
  categoryId Int
}

model Friendship {
  id           Int      @id @default(autoincrement())
  user         User     @relation(fields: [userId], references: [id])
  userId       Int
  dateOfFriend DateTime @db.Date
}

model Comment {
  id        Int        @id @default(autoincrement())
  content   String     @db.LongText
  postId    Int
  userId    Int
  user      User       @relation(fields: [userId], references: [id], map: "Comment_user_fkey")
  post      Post       @relation(fields: [postId], references: [id], map: "Comment_post_fkey")
  replies   Reply[]
  reactions Reaction[]
  createdAt DateTime   @default(now())
}

model Reply {
  id        Int        @id @default(autoincrement())
  content   String     @db.LongText
  commentId Int
  userId    Int
  user      User       @relation(fields: [userId], references: [id], map: "Reply_user_fkey")
  comment   Comment    @relation(fields: [commentId], references: [id], map: "Reply_comment_fkey")
  reactions Reaction[] // Relation with Reaction model
  createdAt DateTime   @default(now())
}

model Reaction {
  id     Int @id @default(autoincrement())
  userId Int

  postId    Int?
  commentId Int?
  replyId   Int?

  type      ReactionType
  createdAt DateTime     @default(now())

  user    User     @relation(fields: [userId], references: [id])
  post    Post?    @relation(fields: [postId], references: [id])
  comment Comment? @relation(fields: [commentId], references: [id])
  reply   Reply?   @relation(fields: [replyId], references: [id])

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@unique([userId, replyId])
}

model Picture {
  id        Int      @id @default(autoincrement())
  url       String   @db.LongText
  name      String
  post      Post?    @relation(fields: [postId], references: [id])
  profile   Profile? @relation(fields: [profileId], references: [id])
  profileId Int?     @unique
  postId    Int?     @unique
}

enum Role {
  USER
  ADMIN
}

enum ReactionType {
  LIKE
  DISLIKE
  FAVORITE
}

model VerificationCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  operation String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
